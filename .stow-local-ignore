# .stow-local-ignore
# NOTE: This file REPLACES stow's built-in ignore list entirely.
# Always replicate the important built-in defaults below.

# --- stow built-in defaults (must be kept here since this file overrides them) ---
CVS
\.cvsignore
\.svn
\.git
\.gitignore
\.gitmodules
_darcs
\.hg
\.bzr
\.bzrignore
RCS
\.stow-local-ignore
\.stow

# --- skills: deployed separately via do-stow.sh symlinks, not as stow packages ---
^skills$

# --- agent guide ---
# AGENTS.md lives in the repo root for agents working inside this repo.
# Instruction symlinks for global use are created outside the repo by do-stow.sh
# (e.g. ~/.claude/CLAUDE.md → dotfiles/AGENTS.md). Nothing to stow here.
^AGENTS\.md$

# --- stow management scripts ---
# These resolve DOTFILES_DIR from ${BASH_SOURCE[0]}. If stowed as ~/do-stow.sh,
# that resolves to ~/ instead of ~/dotfiles/ and the scripts break.
^do-stow\.sh$
^do-unstow\.sh$
